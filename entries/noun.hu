# ダミー名詞（汎用助数詞）
# 数詞の格を担う極小名詞。数詞が属格無標なので、数詞 + tə で格変化可能に。
entry te_dummy {
  headword: "tə"
  tags: [pos=noun, harmony=neutral, animacy=inanim]

  inflect for {case, number} {
    [case=nom, number=sg] -> `tə`
    [case=acc, number=sg] -> `ta`
    [case=gen, number=sg] -> `təmə`
    [case=dat, number=sg] -> `təñ`
    [case=loc, number=sg] -> `tədə`
    [case=com, number=sg] -> `tətə`
    [case=abl, number=sg] -> `təkr̃`
    [case=all, number=sg] -> `təhə`
    [case=nom, number=pl] -> `tərə`
    [case=acc, number=pl] -> `təra`
    [case=gen, number=pl] -> `təmə`
    [case=dat, number=pl] -> `tərəñ`
    [case=loc, number=pl] -> `tərdə`
    [case=com, number=pl] -> `tərtə`
    [case=abl, number=pl] -> `tərəkr̃`
    [case=all, number=pl] -> `tərhə`
  }

  meaning: "汎用ダミー名詞（数詞の格担体、助数詞「つ」に相当）"
  etymology {
    note: "現代日本語「つ」(ひとつ、ふたつの助数詞) → /tsu/ → /tə/（弱化）"
  }
}

