# 光（前舌子音語幹・無生）
entry chikal {
  headword: "çikal"
  tags: [pos=noun, harmony=front, stem_final=cons, animacy=inanim]
  stems { root: "çikal" }
  inflection_class: noun_front_cons_inanim

  meanings {
    light { "光、光明" }
    radiance { "輝き、明るさ" }
    enlightenment { "知識、啓示、理解（比喩的）" }
  }

  etymology {
    note: "現代日本語「ひかり」(光) → /hikari/ → /çikari/ → /çikar/ → /çikal/（ら行 → l）"
  }
}

# 闇（前舌子音語幹・無生）
# jam は中立母音のみだが、歴史的に前舌接辞を引く
entry jam {
  headword: "jami"
  tags: [pos=noun, harmony=front, stem_final=cons, animacy=inanim]
  stems { root: "jam" }
  inflection_class: noun_front_cons_inanim

  meanings {
    darkness { "闇、暗闇、光の欠如" }
    night { "夜、夜間" }
    ignorance { "無知、混乱（比喩的）" }
  }

  etymology {
    note: "現代日本語「やみ」(闇) → /jami/。語幹 jam は中立母音のみだが、語末 -i の前舌性により前舌クラスに定着。"
  }
}

# 水（後舌・無生）
# 音節核は音節主音 m̃
entry miz {
  headword: "m̃z"
  tags: [pos=noun, harmony=back, stem_final=cons, animacy=inanim]
  stems { root: "m̃z" }
  inflection_class: noun_back_cons_inanim

  meanings {
    water { "水、H2O" }
    liquid { "液体、液状のもの" }
  }

  etymology {
    note: "現代日本語「みず」(水) → /mizu/ → /m̃z/（母音脱落、音節主音化）"
  }
}

# 霊（前舌子音語幹・無生）
entry lej {
  headword: "lej"
  tags: [pos=noun, harmony=front, stem_final=cons, animacy=inanim]
  stems { root: "lej" }
  inflection_class: noun_front_cons_inanim

  meanings {
    spirit { "霊、精神的存在" }
    soul { "魂、精神" }
    divine_force { "神聖な力、超自然的存在" }
  }

  etymology {
    note: "現代日本語「れい」(霊) → /reː/ → /rej/ → /lej/（ら行 → l、長母音 → 二重母音 → j コーダ）"
  }
}

# 種類（中立子音語幹・無生）
# wakr（分ける）の受動分詞が語彙化。「分けられたもの」→「種類」
entry wakrel {
  headword: "wakrələ"
  tags: [pos=noun, harmony=neutral, stem_final=cons, animacy=inanim]
  stems { root: "wakrəl" }
  inflection_class: noun_neutral_cons_inanim

  meanings {
    kind { "種類、類" }
    category { "区分、分類" }
  }

  etymology {
    note: "動詞 wakər（分ける）の受動分詞 wakr+rəl（分けられたもの）が語彙化。シュワー挿入前の語幹 wakr を化石的に保持。"
  }
}

# しるし（前舌子音語幹・無生）
# shiles（印す）の受動分詞 shiles+rel が語彙化。「印されたもの」→ しるし
entry shilesrel {
  headword: "ʃilesrel"
  tags: [pos=noun, harmony=front, stem_final=cons, animacy=inanim]
  stems { root: "ʃilesrel" }
  inflection_class: noun_front_cons_inanim

  meanings {
    sign { "しるし、印、目印" }
    omen { "兆し、前兆" }
    token { "証、象徴" }
  }

  etymology {
    note: "動詞 ʃiles（印す）の受動分詞現在形 ʃiles+rel（印されたもの）が実体名詞として語彙化。"
  }
}

