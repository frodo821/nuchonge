# @suppress next-line: glob-import
@use * from "../profile.hu"

# ============================================================
# 名詞
# ============================================================

# 人（前舌子音・有生）
# md では「無生」とラベルされていたが、意味上は有生が正しい
entry chit {
  headword: "çit"
  tags: [pos=noun, harmony=front, stem_final=cons, animacy=anim]
  stems { root: "çit" }
  inflection_class: noun_front_cons_anim

  meanings {
    human { "人間、人類の個体" }
    other { "他者、自分以外の人物" }
  }

  etymology {
    note: "現代日本語「ひと」(人) → /hito/ → /hit/ → /çit/"
  }
}

# 本（後舌子音・無生）
entry hn {
  headword: "hñ"
  tags: [pos=noun, harmony=back, stem_final=cons, animacy=inanim]
  stems { root: "hñ" }
  inflection_class: noun_back_cons_inanim

  meanings {
    book { "印刷または電子化された文字・画像からなる情報媒体" }
    publication { "書籍、図書、出版物" }
    source { "知識や情報の源泉（比喩的用法）" }
    basis { "基本、根本、原理（複合語の中で）" }
  }

  etymology {
    note: "現代日本語「ほん」(本) → /hon/ → /hñ/（母音脱落と子音の音節主音化）"
  }
}

# 家（不規則名詞・無生）
# 単母音語幹で高頻度のため規則クラスに乗らず、全形を直接列挙。
# 不規則性の二重の化石:
#   1. 語幹の化石: /ie/ → /æ/ 融合前の /i/ が格接辞に再分析（-de→-id, -te→-it 等）
#   2. 接辞の化石: gen 古層 -ne は本来保存されるべきだが、dat -iñ との弁別圧力で
#      -me への革新に追従（→ -im）。loc/com/abl は dat と衝突しないため古形保持。
# nom/acc 合流: 単母音の超高頻度語で無標化。
# pl æje: 融合前の /je/ が複数で保存。格接辞は sg と同じ再分析済み -iC を適用。
entry ae {
  headword: "æ"
  tags: [pos=noun, harmony=front, animacy=inanim]

  inflect for {case, number} {
    # 単数
    [case=nom, number=sg] -> `æ`
    [case=acc, number=sg] -> `æ`
    [case=gen, number=sg] -> `æim`
    [case=dat, number=sg] -> `æiñ`
    [case=loc, number=sg] -> `æid`
    [case=com, number=sg] -> `æit`
    [case=abl, number=sg] -> `æikr̃`
    [case=all, number=sg] -> `æihə`
    # 複数
    [case=nom, number=pl] -> `æje`
    [case=acc, number=pl] -> `æje`
    [case=gen, number=pl] -> `æjim`
    [case=dat, number=pl] -> `æjiñ`
    [case=loc, number=pl] -> `æjid`
    [case=com, number=pl] -> `æjit`
    [case=abl, number=pl] -> `æjikr̃`
    [case=all, number=pl] -> `æjihə`
  }

  meanings {
    dwelling { "人が住むための建物、住居" }
    family { "家族や家系を表す社会的単位" }
    place { "慣れ親しんだ場所や環境（比喩的用法）" }
  }

  etymology {
    note: "現代日本語「いえ」(家) → /ie/ → /je/ → /æ/（二重母音の融合）。格変化に二重の化石化: (1) /ie/ の /i/ が格接辞に再分析（ie-de → æ-id 等）、(2) gen 古層 -ne が dat -iñ との弁別圧力で -me に追従（→ æim）。pl æje は融合前の /je/ が複数形で保存。"
  }
}

