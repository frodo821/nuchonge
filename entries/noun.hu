    chaos { "原初の混沌状態（創造物語）" }
  }

  etymology {
    note: "現代日本語「もや」→ /moja/ → /maja/"
  }
}

# 空（後舌子音語幹・無生）
# headword sora の -a は主格語尾。語幹は sor
