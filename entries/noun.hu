  headword: "sora"
  tags: [pos=noun, harmony=back, stem_final=cons, animacy=inanim]
  stems { root: "sor" }
  inflection_class: noun_back_cons_inanim

  meanings {
    sky { "空、大気" }
    heaven { "天空" }
  }

  etymology {
    note: "現代日本語「そら」(空) → /sora/。語幹 sor は指示詞 sor（それ）と同形だが別語源。"
  }
}

