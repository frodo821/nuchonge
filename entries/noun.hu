# 地（後舌・無生）
# 音節核は音節主音 r̃
entry tir {
  headword: "tr̃"
  tags: [pos=noun, harmony=back, stem_final=cons, animacy=inanim]
  stems { root: "tr̃" }
  inflection_class: noun_back_cons_inanim

  meanings {
    earth { "地、大地、土地" }
    world { "地球、世界" }
  }

  etymology {
    note: "現代日本語「ち」(地) → /tʃi/ → /tr̃/（子音+音節主音化）"
  }
}

# 光（前舌子音語幹・無生）
entry chikal {
  headword: "çikal"
  tags: [pos=noun, harmony=front, stem_final=cons, animacy=inanim]
  stems { root: "çikal" }
  inflection_class: noun_front_cons_inanim

  meanings {
    light { "光、光明" }
    radiance { "輝き、明るさ" }
    enlightenment { "知識、啓示、理解（比喩的）" }
  }

  etymology {
    note: "現代日本語「ひかり」(光) → /hikari/ → /çikari/ → /çikar/ → /çikal/（ら行 → l）"
  }
}

# 闇（前舌子音語幹・無生）
# jam は中立母音のみだが、歴史的に前舌接辞を引く
entry jam {
  headword: "jami"
  tags: [pos=noun, harmony=front, stem_final=cons, animacy=inanim]
  stems { root: "jam" }
  inflection_class: noun_front_cons_inanim

  meanings {
    darkness { "闇、暗闇、光の欠如" }
    night { "夜、夜間" }
    ignorance { "無知、混乱（比喩的）" }
  }

  etymology {
    note: "現代日本語「やみ」(闇) → /jami/。語幹 jam は中立母音のみだが、語末 -i の前舌性により前舌クラスに定着。"
  }
}

# 水（後舌・無生）
# 音節核は音節主音 m̃
entry miz {
  headword: "m̃z"
  tags: [pos=noun, harmony=back, stem_final=cons, animacy=inanim]
  stems { root: "m̃z" }
  inflection_class: noun_back_cons_inanim

  meanings {
    water { "水、H2O" }
    liquid { "液体、液状のもの" }
  }

  etymology {
    note: "現代日本語「みず」(水) → /mizu/ → /m̃z/（母音脱落、音節主音化）"
  }
}

# 霊（前舌子音語幹・無生）
entry lej {
  headword: "lej"
  tags: [pos=noun, harmony=front, stem_final=cons, animacy=inanim]
  stems { root: "lej" }
  inflection_class: noun_front_cons_inanim

  meanings {
    spirit { "霊、精神的存在" }
    soul { "魂、精神" }
    divine_force { "神聖な力、超自然的存在" }
  }

  etymology {
    note: "現代日本語「れい」(霊) → /reː/ → /rej/ → /lej/（ら行 → l、長母音 → 二重母音 → j コーダ）"
  }
}
