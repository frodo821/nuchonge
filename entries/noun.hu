# 太陽（前舌母音語幹・無生）
# çikal (光) の語根 hi が天体名として古形保持。ça (日) が日常語として音変化した一方で、
# 天体としての「太陽」は神聖語彙として古い形を保つ。
entry hi {
  headword: "hi"
  tags: [pos=noun, harmony=front, stem_final=front_vowel, animacy=inanim]
  stems { root: "hi" }
  inflection_class: noun_front_v_inanim

  meanings {
    sun { "太陽、天体としての太陽" }
  }

  etymology {
    note: "現代日本語「ひ」(日) → /hi/。ça (日・一日) が音変化を経た一方、天体名としての hi は古形を保持。çikal (光) の語根。"
  }
}

# 木（前舌母音語幹・無生）
entry ki {
  headword: "ki"
  tags: [pos=noun, harmony=front, stem_final=front_vowel, animacy=inanim]
  stems { root: "ki" }
  inflection_class: noun_front_v_inanim

  meanings {
    tree { "樹木、幹と枝と葉を持つ大型の多年生植物" }
    wood { "木材、材木" }
  }

  etymology {
    note: "現代日本語「き」(木) → /ki/。短母音単音節のため変形を受けず保存。"
  }
}

# 男（後舌子音語幹・有生）
entry ot {
  headword: "ot"
  tags: [pos=noun, harmony=back, stem_final=cons, animacy=anim]
  stems { root: "ot" }
  inflection_class: noun_back_cons_anim

  meaning: "男、男性"

  etymology {
    note: "現代日本語「おとこ」(男) → /otoko/ → /otok/ → /ot/"
  }
}

# 女（前舌母音語幹・有生）
entry me_f {
  headword: "me"
  tags: [pos=noun, harmony=front, stem_final=front_vowel, animacy=anim]
  stems { root: "me" }
  inflection_class: noun_front_v_anim

  meaning: "女、女性"

  etymology {
    note: "古語「め」(女)。女神(megami)・乙女(otome)に残る古い語根を保持。"
  }
}

# 獣（後舌子音語幹・有生）
entry kemon {
  headword: "kəmon"
  tags: [pos=noun, harmony=back, stem_final=cons, animacy=anim]
  stems { root: "kəmon" }
  inflection_class: noun_back_cons_anim

  meaning: "獣、野生の動物"

  etymology {
    note: "現代日本語「けもの」(獣) → /kemono/ → /kəmon/ (e→ə 弱化、語末母音脱落)"
  }
}

# 家畜（前舌子音語幹・有生）
# ækil (家に生きる) + er (能動分詞) が語彙化
entry aekiler {
  headword: "ækileri"
  tags: [pos=noun, harmony=front, stem_final=cons, animacy=anim]
  stems { root: "ækiler" }
  inflection_class: noun_front_cons_anim

  meaning: "家畜、飼育される動物"

  etymology {
    note: "æ（家）+ ikil（生きる）+ er（能動分詞）の融合語彙化。「家に生きるもの」= 家畜。"
  }
}

# 魚（中立子音語幹・有生）
entry sakn {
  headword: "sakən"
  tags: [pos=noun, harmony=neutral, stem_final=cons, animacy=anim]
  stems { root: "sakən" }
  inflection_class: noun_neutral_cons_anim

  meaning: "魚、水中に生息する脊椎動物"

  etymology {
    note: "現代日本語「さかな」(魚) → /sakana/ → /sakan/ → /sakən/ (語末母音弱化)"
  }
}

# 鳥（後舌子音語幹・有生）
entry tol {
  headword: "tol"
  tags: [pos=noun, harmony=back, stem_final=cons, animacy=anim]
  stems { root: "tol" }
  inflection_class: noun_back_cons_anim

  meaning: "鳥、翼を持つ動物"

  etymology {
    note: "現代日本語「とり」(鳥) → /tori/ → /tol/ (r→l、語末母音脱落)"
  }
}

# 生き物（前舌子音語幹・有生）
# ikil（生きる）の能動分詞現在形 ikil+er が語彙化。「生きているもの」→ 生き物
entry ikiler {
  headword: "ikileri"
  tags: [pos=noun, harmony=front, stem_final=cons, animacy=anim]
  stems { root: "ikiler" }
  inflection_class: noun_front_cons_anim

  meanings {
    creature { "生き物、生命ある存在" }
    living_being { "生物、動物全般" }
  }

  etymology {
    note: "動詞 ikil（生きる）の能動分詞現在形 ikil+er（生きているもの）が実体名詞として語彙化。有生名詞。"
  }
}

# 種（中立子音語幹・無生）
entry tan {
  headword: "tan"
  tags: [pos=noun, harmony=neutral, stem_final=cons, animacy=inanim]
  stems { root: "tan" }
  inflection_class: noun_neutral_cons_inanim

  meanings {
    seed { "種子、植物の繁殖器官" }
    kind { "種類、類（比喩的）" }
  }

  etymology {
    note: "現代日本語「たね」(種) → /tane/ → /tan/"
  }
}

# 草（後舌子音語幹・無生）
entry kush {
  headword: "kuʃ"
  tags: [pos=noun, harmony=back, stem_final=cons, animacy=inanim]
  stems { root: "kuʃ" }
  inflection_class: noun_back_cons_inanim

  meanings {
    grass { "草、草本植物" }
    herb { "薬草、食用の草" }
  }

  etymology {
    note: "現代日本語「くさ」(草) → /kusa/ → /kuʃ/ (語末 a 脱落、s→ʃ 口蓋化)"
  }
}

# 植物（前舌子音語幹・無生）
# hae（生える）の能動分詞現在形 ha+er が語彙化した実体名詞
entry haer {
  headword: "haeri"
  tags: [pos=noun, harmony=front, stem_final=cons, animacy=inanim]
  stems { root: "haer" }
  inflection_class: noun_front_cons_inanim

  meanings {
    vegetation { "植物、草木の総称" }
    plant { "地に生える生物全般" }
  }

  etymology {
    note: "動詞 hae（生える）の能動分詞現在形 ha+er（生えているもの）が実体名詞として語彙化。形容詞→名詞の転成。"
  }
}

# 所（後舌子音語幹・無生）
entry tokl {
  headword: "tokl"
  tags: [pos=noun, harmony=back, stem_final=cons, animacy=inanim]
  stems { root: "tokl" }
  inflection_class: noun_back_cons_inanim

  meanings {
    place { "場所、位置" }
    spot { "地点、箇所" }
  }

  etymology {
    note: "現代日本語「ところ」(所) → /tokoro/ → /tokol/ (r→l) → /tokl/ (母音脱落)"
  }
}

# 陸（後舌子音語幹・無生）
# 母音が全て脱落した重子音語幹
entry rk {
  headword: "r̃k"
  tags: [pos=noun, harmony=back, stem_final=cons, animacy=inanim]
  stems { root: "r̃k" }
  inflection_class: noun_back_cons_inanim

  meanings {
    land { "陸地、海に対する乾いた地面" }
    continent { "大陸、広大な土地" }
  }

  etymology {
    note: "現代日本語「りく」(陸) → /riku/ → /r̃k/（母音脱落、音節主音化）"
  }
}
