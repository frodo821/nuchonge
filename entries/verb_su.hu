# @suppress next-line: glob-import
@use * from "../profile.hu"

# ============================================================
# 不規則動詞 su（する/なす統合）
# ============================================================
# 3語幹: su (←する, 現在), na (←なす, 過去), si (←内的ablaut, 未来)
# 母音ablaut: u (現在) / a (過去) / i (未来)
#
# 融合規則:
#   - 相接辞が語幹子音と直接結合 → CC クラスタ発生
#   - 現在: 時制母音 e を挿入して解消 (s-e-C-e)
#   - 過去: n→ñ 変異で吸収 (ñ-C-a)。ñ が過去 su の標識
#   - 未来: 時制母音 i を挿入して解消 (s-i-C-i)
#   - impf: 相接辞なし → 素の語幹 su/na/si
#
# 2sg: 後舌上昇 u→uj を規則適用 (leveling)
#   対面発話の高頻度で規則パターンに引き戻された
#
# 人称標識: 通常通り (-w, -l, -s, -r, 2sg上昇)
# 否定: 鼻母音化規則適用

entry su {
  headword: "su"
  tags: [pos=verb, harmony=front]

  inflect for {tense, aspect, person, number, polarity} {
    # ══════════════════════════════════════
    # 現在 (su 語幹, 時制母音 e)
    # ══════════════════════════════════════

