  [case=nom, number=pl] -> `{root}eriŋ`
  [case=acc, number=pl] -> `{root}ereŋ`
  [case=gen, number=pl] -> `{root}emeŋ`
  [case=dat, number=pl] -> `{root}eriŋ`
