  [case=dat, number=sg] -> `{root}uñ`
  [case=loc, number=sg] -> `{root}do`
  [case=com, number=sg] -> `{root}to`
  [case=abl, number=sg] -> `{root}ukr̃`
  [case=all, number=sg] -> `{root}uh`
  # 複数 — or- 無生、古層融合
  [case=nom, number=pl] -> `{root}ora`
  [case=acc, number=pl] -> `{root}oro`
  [case=gen, number=pl] -> `{root}omo`
  [case=dat, number=pl] -> `{root}oruñ`
  [case=loc, number=pl] -> `{root}ordo`
  [case=com, number=pl] -> `{root}orto`
  [case=abl, number=pl] -> `{root}orukr̃`
  [case=all, number=pl] -> `{root}oruh`
}

