# ── 中立母音語幹 a/ə・有生（j 滑音）──
# 前舌 i/e/æ 語幹 → j 滑音、後舌 a 語幹 → j 滑音の中間。
# 格母音は中立子音語幹と平行（ə/a）。複数有生: 主対は単数と同形、ə 挿入。
inflection noun_neutral_v_anim for {case, number} {
  requires stems: root
  apply cc_epenthesis(cell)
  [case=nom, number=sg] -> `{root}jə`
  [case=acc, number=sg] -> `{root}ja`
  [case=gen, number=sg] -> `{root}nə`
  [case=dat, number=sg] -> `{root}ñ`
  [case=loc, number=sg] -> `{root}də`
  [case=com, number=sg] -> `{root}tə`
  [case=abl, number=sg] -> `{root}kr̃`
  [case=all, number=sg] -> `{root}hə`
  # 複数 — 有生: 主格・対格は単数と同形
  [case=nom, number=pl] -> `{root}jə`
  [case=acc, number=pl] -> `{root}ja`
  [case=gen, number=pl] -> `{root}ənə`
  [case=dat, number=pl] -> `{root}əñ`
  [case=loc, number=pl] -> `{root}ədə`
  [case=com, number=pl] -> `{root}ətə`
  [case=abl, number=pl] -> `{root}əkr̃`
  [case=all, number=pl] -> `{root}əhə`
}

# ── 中立母音語幹 a/ə・無生 ──
# 複数無生: r- 標識（前舌 r- / 後舌 r- と同形）
inflection noun_neutral_v_inanim for {case, number} {
  requires stems: root
  apply cc_epenthesis(cell)
  [case=nom, number=sg] -> `{root}jə`
  [case=acc, number=sg] -> `{root}ja`
  [case=gen, number=sg] -> `{root}mə`
  [case=dat, number=sg] -> `{root}ñ`
  [case=loc, number=sg] -> `{root}də`
  [case=com, number=sg] -> `{root}tə`
  [case=abl, number=sg] -> `{root}kr̃`
  [case=all, number=sg] -> `{root}hə`
  # 複数 — 無生 r-
  [case=nom, number=pl] -> `{root}rə`
  [case=acc, number=pl] -> `{root}ra`
  [case=gen, number=pl] -> `{root}rmə`
  [case=dat, number=pl] -> `{root}rəñ`
  [case=loc, number=pl] -> `{root}rdə`
  [case=com, number=pl] -> `{root}rtə`
  [case=abl, number=pl] -> `{root}rəkr̃`
  [case=all, number=pl] -> `{root}rhə`
}

# ── 中立子音語幹・有生 ──
# 中立母音 ə/a を使用。格語尾は前舌/後舌と平行。
# 複数標識: 有生 ər-（前舌 ir- / 後舌 ar- の中間）
inflection noun_neutral_cons_anim for {case, number} {
  requires stems: root
  apply cc_epenthesis(cell)
  [case=nom, number=sg] -> `{root}ə`
  [case=acc, number=sg] -> `{root}a`
  [case=gen, number=sg] -> `{root}nə`
  [case=dat, number=sg] -> `{root}əñ`
  [case=loc, number=sg] -> `{root}də`
  [case=com, number=sg] -> `{root}tə`
  [case=abl, number=sg] -> `{root}əkr̃`
  [case=all, number=sg] -> `{root}hə`
  # 複数 — 有生 ər-
  [case=nom, number=pl] -> `{root}rə`
  [case=acc, number=pl] -> `{root}ra`
  [case=gen, number=pl] -> `{root}ənə`
  [case=dat, number=pl] -> `{root}ərəñ`
  [case=loc, number=pl] -> `{root}ərdə`
  [case=com, number=pl] -> `{root}ərtə`
  [case=abl, number=pl] -> `{root}ərəkr̃`
  [case=all, number=pl] -> `{root}ərhə`
}

# ── 中立子音語幹・無生 ──
# 複数標識: 無生 ər-（前舌 er- / 後舌 or- の中間）
inflection noun_neutral_cons_inanim for {case, number} {
  requires stems: root
  apply cc_epenthesis(cell)
  [case=nom, number=sg] -> `{root}ə`
  [case=acc, number=sg] -> `{root}a`
  [case=gen, number=sg] -> `{root}mə`
  [case=dat, number=sg] -> `{root}əñ`
  [case=loc, number=sg] -> `{root}də`
  [case=com, number=sg] -> `{root}tə`
  [case=abl, number=sg] -> `{root}əkr̃`
  [case=all, number=sg] -> `{root}hə`
  # 複数 — 無生 ər-
  [case=nom, number=pl] -> `{root}ərə`
  [case=acc, number=pl] -> `{root}əra`
  [case=gen, number=pl] -> `{root}əmə`
  [case=dat, number=pl] -> `{root}ərəñ`
  [case=loc, number=pl] -> `{root}ərdə`
  [case=com, number=pl] -> `{root}ərtə`
  [case=abl, number=pl] -> `{root}ərəkr̃`
  [case=all, number=pl] -> `{root}ərhə`
}

# ============================================================
# 形容詞曲用
# ============================================================
# 形容詞は修飾する名詞の格・数・有生性に一致変化する。
# リンカー nə が格語尾と融合し、名詞曲用と体系的に区別される。
#
# 融合規則:
#   1. 母音語尾 + nə → Vŋ（n が coda で ŋ に安定）
#   2. ɲ(ñ) + nə → ŋ（鼻音の調音点が置換。名詞 -iɲ/dat vs 形容詞 -iŋ/dat）
#   3. h + nə → ŋ（h が吸収。後舌で与格と向格が合流するが名詞で区別可能）
#   4. その他の子音 + nə → Cəŋ（シュワー挿入）
#
# 比較級: -jər 接辞。比較級も同じリンカー融合曲用を使う。
# 語源: 「より」/jori/ → /jor/ → /jər/（弱化で中立母音に）
# 最上級: sə + 比較級（分析的、統語レベルで処理）

# ── リンカー融合済み形容詞曲用（基底クラス）──

# 前舌子音語幹・有生
inflection adj_link_front_cons_anim for {case, number} {
  requires stems: root
  apply geminate_j(cc_epenthesis(cell))
  [case=nom, number=sg] -> `{root}iŋ`
  [case=acc, number=sg] -> `{root}eŋ`
  [case=gen, number=sg] -> `{root}neŋ`
  [case=dat, number=sg] -> `{root}iŋ`
  [case=loc, number=sg] -> `{root}deŋ`
  [case=com, number=sg] -> `{root}teŋ`
  [case=abl, number=sg] -> `{root}ikr̃əŋ`
  [case=all, number=sg] -> `{root}heŋ`
  [case=nom, number=pl] -> `{root}riŋ`
  [case=acc, number=pl] -> `{root}reŋ`
  [case=gen, number=pl] -> `{root}ineŋ`
  [case=dat, number=pl] -> `{root}iriŋ`
  [case=loc, number=pl] -> `{root}irdeŋ`
  [case=com, number=pl] -> `{root}irteŋ`
  [case=abl, number=pl] -> `{root}irikr̃əŋ`
  [case=all, number=pl] -> `{root}irheŋ`
}

