  [case=gen, number=sg] -> `{root}moŋ`
  [case=dat, number=sg] -> `{root}uŋ`
  [case=loc, number=sg] -> `{root}doŋ`
  [case=com, number=sg] -> `{root}toŋ`
  [case=abl, number=sg] -> `{root}ukr̃əŋ`
  [case=all, number=sg] -> `{root}uŋ`
  [case=nom, number=pl] -> `{root}oraŋ`
  [case=acc, number=pl] -> `{root}oroŋ`
  [case=gen, number=pl] -> `{root}omoŋ`
  [case=dat, number=pl] -> `{root}oruŋ`
  [case=loc, number=pl] -> `{root}ordoŋ`
  [case=com, number=pl] -> `{root}ortoŋ`
  [case=abl, number=pl] -> `{root}orukr̃əŋ`
  [case=all, number=pl] -> `{root}oruŋ`
}

# 中立子音語幹・有生
inflection adj_link_neutral_cons_anim for {case, number} {
  requires stems: root
  apply geminate_j(cc_epenthesis(cell))
  [case=nom, number=sg] -> `{root}əŋ`
  [case=acc, number=sg] -> `{root}aŋ`
  [case=gen, number=sg] -> `{root}nəŋ`
  [case=dat, number=sg] -> `{root}əŋ`
  [case=loc, number=sg] -> `{root}dəŋ`
  [case=com, number=sg] -> `{root}təŋ`
  [case=abl, number=sg] -> `{root}əkr̃əŋ`
  [case=all, number=sg] -> `{root}əŋ`
  [case=nom, number=pl] -> `{root}rəŋ`
  [case=acc, number=pl] -> `{root}raŋ`
  [case=gen, number=pl] -> `{root}ənəŋ`
  [case=dat, number=pl] -> `{root}ərəŋ`
  [case=loc, number=pl] -> `{root}ərdəŋ`
  [case=com, number=pl] -> `{root}ərtəŋ`
  [case=abl, number=pl] -> `{root}ərəkr̃əŋ`
  [case=all, number=pl] -> `{root}ərhəŋ`
}

# 中立子音語幹・無生
inflection adj_link_neutral_cons_inanim for {case, number} {
  requires stems: root
  apply geminate_j(cc_epenthesis(cell))
  [case=nom, number=sg] -> `{root}əŋ`
  [case=acc, number=sg] -> `{root}aŋ`
  [case=gen, number=sg] -> `{root}məŋ`
  [case=dat, number=sg] -> `{root}əŋ`
  [case=loc, number=sg] -> `{root}dəŋ`
  [case=com, number=sg] -> `{root}təŋ`
  [case=abl, number=sg] -> `{root}əkr̃əŋ`
  [case=all, number=sg] -> `{root}əŋ`
  [case=nom, number=pl] -> `{root}ərəŋ`
  [case=acc, number=pl] -> `{root}əraŋ`
  [case=gen, number=pl] -> `{root}əməŋ`
  [case=dat, number=pl] -> `{root}ərəŋ`
  [case=loc, number=pl] -> `{root}ərdəŋ`
  [case=com, number=pl] -> `{root}ərtəŋ`
  [case=abl, number=pl] -> `{root}ərəkr̃əŋ`
  [case=all, number=pl] -> `{root}ərhəŋ`
}

# ── ディスパッチ（比較級共通）──

inflection adj_comp_front for {case, number, animacy} {
  requires stems: root
  [animacy=anim, _] -> adj_link_front_cons_anim[case, number] with stems { root: root }
  [animacy=inanim, _] -> adj_link_front_cons_inanim[case, number] with stems { root: root }
}

inflection adj_comp_back for {case, number, animacy} {
  requires stems: root
  [animacy=anim, _] -> adj_link_back_cons_anim[case, number] with stems { root: root }
  [animacy=inanim, _] -> adj_link_back_cons_inanim[case, number] with stems { root: root }
}

inflection adj_comp_neutral for {case, number, animacy} {
  requires stems: root
  [animacy=anim, _] -> adj_link_neutral_cons_anim[case, number] with stems { root: root }
  [animacy=inanim, _] -> adj_link_neutral_cons_inanim[case, number] with stems { root: root }
}

# ── 原級・比較級・名詞化ディスパッチ ──
# degree=nmlz: 形容詞語幹を名詞活用クラスに流す（「〜さ」の派生）
# リンカー ŋ が落ちることで形容詞→抽象名詞:
#   ɔkaŋ (大きい) → ɔka (大きさ), çisiŋ (小さい) → çisi (小ささ)
# 抽象名詞は常に無生。

inflection adj_front_cons for {case, number, animacy, degree} {
  requires stems: root, comp
  [degree=pos, animacy=anim, _] -> adj_link_front_cons_anim[case, number] with stems { root: root }
  [degree=pos, animacy=inanim, _] -> adj_link_front_cons_inanim[case, number] with stems { root: root }
  [degree=comp, _] -> adj_comp_front[case, number, animacy] with stems { root: comp }
  [degree=nmlz, _] -> noun_front_cons_inanim[case, number] with stems { root: root }
}

inflection adj_back_cons for {case, number, animacy, degree} {
  requires stems: root, comp
  [degree=pos, animacy=anim, _] -> adj_link_back_cons_anim[case, number] with stems { root: root }
  [degree=pos, animacy=inanim, _] -> adj_link_back_cons_inanim[case, number] with stems { root: root }
  [degree=comp, _] -> adj_comp_back[case, number, animacy] with stems { root: comp }
  [degree=nmlz, _] -> noun_back_cons_inanim[case, number] with stems { root: root }
}

inflection adj_front_v for {case, number, animacy, degree} {
  requires stems: root, comp
  [degree=pos, animacy=anim, _] -> adj_link_front_cons_anim[case, number] with stems { root: root }
  [degree=pos, animacy=inanim, _] -> adj_link_front_cons_inanim[case, number] with stems { root: root }
  [degree=comp, _] -> adj_comp_front[case, number, animacy] with stems { root: comp }
  [degree=nmlz, _] -> noun_front_cons_inanim[case, number] with stems { root: root }
}

inflection adj_back_ov for {case, number, animacy, degree} {
  requires stems: root, comp
  [degree=pos, animacy=anim, _] -> adj_link_back_cons_anim[case, number] with stems { root: root }
  [degree=pos, animacy=inanim, _] -> adj_link_back_cons_inanim[case, number] with stems { root: root }
  [degree=comp, _] -> adj_comp_back[case, number, animacy] with stems { root: comp }
  [degree=nmlz, _] -> noun_back_cons_inanim[case, number] with stems { root: root }
}

inflection adj_back_av for {case, number, animacy, degree} {
  requires stems: root, comp
  [degree=pos, animacy=anim, _] -> adj_link_back_cons_anim[case, number] with stems { root: root }
  [degree=pos, animacy=inanim, _] -> adj_link_back_cons_inanim[case, number] with stems { root: root }
  [degree=comp, _] -> adj_comp_back[case, number, animacy] with stems { root: comp }
  [degree=nmlz, _] -> noun_back_cons_inanim[case, number] with stems { root: root }
}

inflection adj_neutral_cons for {case, number, animacy, degree} {
  requires stems: root, comp
  [degree=pos, animacy=anim, _] -> adj_link_neutral_cons_anim[case, number] with stems { root: root }
  [degree=pos, animacy=inanim, _] -> adj_link_neutral_cons_inanim[case, number] with stems { root: root }
  [degree=comp, _] -> adj_comp_neutral[case, number, animacy] with stems { root: comp }
  [degree=nmlz, _] -> noun_neutral_cons_inanim[case, number] with stems { root: root }
}

# ============================================================
# 代名詞・指示詞
# ============================================================
# 人称代名詞は不規則曲用が多く、各 entry で inline inflect を使用する。
# 共通の特徴:
#   - 人称代名詞は所格を持たない（人は場所たりえない → null）
#   - 指示詞 kor/sor/dor は語幹交替あり（kor-/kok- の補充形）で規則的
#   - 遠称 ar は不規則（所格=出格の合流など）
#
# 副詞接頭辞（ma-, mr-, sæ-, jk-, tv-, hb-）は動詞活用の一部ではなく
# 独立した語彙項目として扱い、.hut ファイルでは ~ で動詞に結合する。
# 例: ma~jomuw (もう読んでいる)

# 規則的指示詞の曲用（kor, sor, dor 共通パターン）
# 軽語幹（kor-）: 主・対・与・属・共  重語幹（kok-）: 所・出・向
inflection demonstrative display { ja: "指示詞" } for {case, number} {
  requires stems: light, heavy
  apply cc_epenthesis(cell)

  # 単数
  [case=nom, number=sg] -> `{light}i`
  [case=acc, number=sg] -> `{light}e`
  [case=dat, number=sg] -> `{light}ñ`
  [case=gen, number=sg] -> `{light}ne`
  [case=loc, number=sg] -> `{heavy}`
  [case=abl, number=sg] -> `{heavy}r`
  [case=all, number=sg] -> `{heavy}ñ`
  [case=com, number=sg] -> `{light}t`

  # 複数
  [case=nom, number=pl] -> `{light}ir`
  [case=acc, number=pl] -> `{light}er`
  [case=dat, number=pl] -> `{light}ñr`
  [case=gen, number=pl] -> `{light}ner`
  [case=loc, number=pl] -> `{heavy}id`
  [case=abl, number=pl] -> `{heavy}ikr̃`
  [case=all, number=pl] -> `{heavy}iñ`
  [case=com, number=pl] -> `{light}it`
}
