# @suppress entire-file: unused-inflection, glob-import
# ヌヒョン語名詞・形容詞・指示詞曲用

@use * from "tags.hu"
@use cc_epenthesis from "phonrules.hu"

# ============================================================
# 名詞曲用
# ============================================================
# 有生/無生は別クラス（属格: 有生 -ne/-no, 無生 -me/-mo、複数標識も異なる）
# 定性は曲用に含めず、指示詞属格（sorne 等）で分析的に表現
# 軸: {case, number} のみ（8格 × 2数 = 16形）
#
# 格の歴史的地層:
#   古層（融合的）: 主格・対格・属格 — 複数で数+格が融合
#   中層（半融合）: 与格・所格・共格 — 所格 -de/-do, 共格 -te/-to に母音化石化
#   新層（膠着的）: 出格・向格 — 子音骨格 + 挿入母音で透明

# ── 前舌子音語幹・有生 ──
# 例: çit (人)
inflection noun_front_cons_anim for {case, number} {
  requires stems: root
  apply cc_epenthesis(cell)
  # 単数
  [case=nom, number=sg] -> `{root}i`
  [case=acc, number=sg] -> `{root}e`
  [case=gen, number=sg] -> `{root}ne`
  [case=dat, number=sg] -> `{root}iñ`
  [case=loc, number=sg] -> `{root}de`
  [case=com, number=sg] -> `{root}te`
  [case=abl, number=sg] -> `{root}ikr̃`
  [case=all, number=sg] -> `{root}he`
  # 複数 — 古層は融合（ir+格 → 縮約）
  [case=nom, number=pl] -> `{root}ri`
  [case=acc, number=pl] -> `{root}re`
  [case=gen, number=pl] -> `{root}ine`
  [case=dat, number=pl] -> `{root}iriñ`
  [case=loc, number=pl] -> `{root}irde`
  [case=com, number=pl] -> `{root}irte`
  [case=abl, number=pl] -> `{root}irikr̃`
  [case=all, number=pl] -> `{root}irhe`
}

# ── 前舌子音語幹・無生 ──
# 例: hin (品)
inflection noun_front_cons_inanim for {case, number} {
  requires stems: root
  apply cc_epenthesis(cell)
  [case=nom, number=sg] -> `{root}i`
  [case=acc, number=sg] -> `{root}e`
  [case=gen, number=sg] -> `{root}me`
  [case=dat, number=sg] -> `{root}iñ`
  [case=loc, number=sg] -> `{root}de`
  [case=com, number=sg] -> `{root}te`
  [case=abl, number=sg] -> `{root}ikr̃`
  [case=all, number=sg] -> `{root}he`
  # 複数 — 無生複数 er-、古層は融合
  [case=nom, number=pl] -> `{root}eri`
  [case=acc, number=pl] -> `{root}ere`
  [case=gen, number=pl] -> `{root}eme`
  [case=dat, number=pl] -> `{root}eriñ`
  [case=loc, number=pl] -> `{root}erde`
  [case=com, number=pl] -> `{root}erte`
  [case=abl, number=pl] -> `{root}erikr̃`
  [case=all, number=pl] -> `{root}erhe`
}

# ── 後舌子音語幹・有生 ──
inflection noun_back_cons_anim for {case, number} {
  requires stems: root
  apply cc_epenthesis(cell)
  [case=nom, number=sg] -> `{root}a`
  [case=acc, number=sg] -> `{root}o`
  [case=gen, number=sg] -> `{root}no`
  [case=dat, number=sg] -> `{root}uñ`
  [case=loc, number=sg] -> `{root}do`
  [case=com, number=sg] -> `{root}to`
  [case=abl, number=sg] -> `{root}ukr̃`
  [case=all, number=sg] -> `{root}uh`
  # 複数 — ar- 有生、古層融合
  [case=nom, number=pl] -> `{root}ra`
  [case=acc, number=pl] -> `{root}ro`
  [case=gen, number=pl] -> `{root}ano`
  [case=dat, number=pl] -> `{root}aruñ`
  [case=loc, number=pl] -> `{root}ardo`
  [case=com, number=pl] -> `{root}arto`
  [case=abl, number=pl] -> `{root}arukr̃`
  [case=all, number=pl] -> `{root}aruh`
}

# ── 後舌子音語幹・無生 ──
# 例: hñ (本)
inflection noun_back_cons_inanim for {case, number} {
  requires stems: root
  apply cc_epenthesis(cell)
  [case=nom, number=sg] -> `{root}a`
